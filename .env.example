# =============================================================================
# HandwerkerBrief - Umgebungsvariablen
# Kopiere diese Datei zu .env:  cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Datenbank (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=handwerker
POSTGRES_PASSWORD=sicheres_passwort_hier_eintragen
POSTGRES_DB=handwerkerbrief

# -----------------------------------------------------------------------------
# Sicherheit
# Zufälligen Schlüssel generieren mit: openssl rand -hex 32
# -----------------------------------------------------------------------------
SECRET_KEY=hier_openssl_rand_hex_32_ausgabe_eintragen

# -----------------------------------------------------------------------------
# SMTP E-Mail (optional)
# Ohne SMTP funktioniert die App, nur keine E-Mails werden versendet.
# Beispiel Gmail: smtp.gmail.com | Strato: smtp.strato.de | Port: 587
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.dein-anbieter.de
SMTP_PORT=587
SMTP_USER=noreply@deine-domain.de
SMTP_PASSWORD=dein_smtp_passwort
SMTP_FROM=HandwerkerBrief <noreply@deine-domain.de>

# -----------------------------------------------------------------------------
# URLs
# APP_URL: Öffentliche URL der App (für Links in E-Mails)
# NEXT_PUBLIC_API_URL: /api wenn nginx auf Port 80 (Standard)
# -----------------------------------------------------------------------------
APP_URL=http://localhost
NEXT_PUBLIC_API_URL=/api

# -----------------------------------------------------------------------------
# Umgebung
# -----------------------------------------------------------------------------
ENVIRONMENT=production
